{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/cron/scraping-schedule", "schedule": "0 9 * * *" },
    { "path": "/api/cron/scraping-enrich", "schedule": "0 10 * * *" },
    { "path": "/api/cron/scraping-narratives", "schedule": "0 11 * * *" }
  ]
}
